{
  "name": "discord-contribution-leaderboard",
  "version": "0.1.0",
  "private": true,
  "description": "Chrome extension that captures visible Discord activity and builds a local leaderboard.",
  "packageManager": "pnpm@10.2.0",
  "scripts": {
    "build": "tsc -p tsconfig.json && tsx src/build/cli.ts",
    "biome:staged": "node scripts/run-biome-on-staged.mjs",
    "check": "tsc -p tsconfig.json",
    "format": "biome format --write .",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "prepare": "husky",
    "precommit": "node scripts/run-pnpm.mjs run biome:staged && node scripts/run-pnpm.mjs run secrets:staged",
    "prepush": "node scripts/run-pnpm.mjs run secrets:repo",
    "tests": "vitest run",
    "secrets:repo": "node scripts/check-secrets.mjs --repo",
    "secrets:staged": "node scripts/check-secrets.mjs --staged",
    "types": "tsc -p tsconfig.json",
    "watch": "tsx src/build/cli.ts --watch",
    "ralph": "bash ralph/afk.sh",
    "cheq": "node scripts/run-pnpm.mjs lint && node scripts/run-pnpm.mjs types && node scripts/run-pnpm.mjs tests"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@secretlint/secretlint-rule-preset-recommend": "^11.7.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^24.7.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "esbuild": "^0.28.0",
    "husky": "^9.1.7",
    "jsdom": "^27.0.1",
    "secretlint": "^11.7.1",
    "tsx": "^4.20.6",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
